# ==========================================
# 本地开发环境配置模板
# Local Development Configuration Template
# ==========================================
#
# 使用说明：
# 1. 复制此文件为 .env
#    cp .env.local.example .env
#
# 2. 修改 .env 中的数据库和 Redis 配置
#    根据你的实际环境填写数据库主机、用户名、密码等
#
# 3. 运行项目
#    go run main.go
#    或
#    ./new-api
#

# PostgreSQL 配置
# 格式: postgresql://用户名:密码@主机:端口/数据库名
SQL_DSN=postgresql://root:123456@your-postgres-host:5432/new-api

# Redis 配置
# 格式: redis://[:密码@]主机:端口[/数据库编号]
REDIS_CONN_STRING=redis://localhost:6379

# 基础配置
PORT=3000
TZ=Asia/Shanghai
DEBUG=true
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
SYNC_FREQUENCY=60
STREAMING_TIMEOUT=300

# 数据库连接池
SQL_MAX_IDLE_CONNS=10
SQL_MAX_OPEN_CONNS=100
SQL_MAX_LIFETIME=60
